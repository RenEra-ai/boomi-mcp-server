# Pinned knowledge-base-builder release. Loaded by cloudbuild.yaml's
# LoadKBPin step and passed as the KB_RELEASE_TAG Docker build arg.
#
# Required: the corresponding GitHub release MUST exist in
# RenEra-ai/knowledge-base-builder with a boomi_knowledge_db.tar.gz asset
# BEFORE this change reaches main, otherwise the PreflightKBAsset step in
# cloudbuild.yaml will fail. Bump this value only after the release is cut.
#
# Format: a single shell-style assignment, safe for `set -a; . this-file`.
KB_RELEASE_TAG=kb-24
