import java.io.InputStream
import groovy.json.StringEscapeUtils
import groovy.json.JsonSlurper
import groovy.json.JsonOutput

import com.boomi.execution.ExecutionUtil
import com.boomi.execution.ExecutionManager

//Examples:
//  def splitPath = props.getProperty("document.dynamic.userdefined.DDP_jsonSplitPath")
//  ExecutionUtil.setDynamicProcessProperty("DPP_countTotal", Integer.toString(intCountTotal), false);

void logger(String message) {
 ExecutionManager.getCurrent().getBaseLogger().info(message)
 //println(message)
}

void loggerSevere(String message) {
 ExecutionManager.getCurrent().getBaseLogger().severe(message)
 //println(message)
}

for( int i = 0; i &lt; dataContext.getDataCount(); i++ ) {
    InputStream is = dataContext.getStream(i);
    Properties props = dataContext.getProperties(i);

    def rawObj = props.getProperty("document.dynamic.userdefined.DDP_LOBJ")
    def rawSql = props.getProperty("document.dynamic.userdefined.DDP_LSQL")

    //logger("rawSql:" + rawSql)
    //logger("rawObj:" + rawObj)

    if (rawObj != null &amp;&amp; rawObj != "" &amp;&amp; rawSql != "" &amp;&amp; rawSql != null) {

        //logger("rawSql:" + rawSql)
        //logger("rawObj:" + rawObj)

        rawObj = rawObj.replaceAll("\t"," ")
        rawSql = rawSql.replaceAll("\t"," ")

        //logger("rawSql after tab:" + rawSql)
        //logger("rawObj after tab:" + rawObj)

        def json = [:]
        json.putAt("Object", rawObj)
        json.putAt("SqlStatement", rawSql)

        def output =  JsonOutput.toJson(json)
       // logger("SqlStatement:" + output)
        is = new ByteArrayInputStream(output.getBytes("UTF-8"))
        props = new Properties()
        dataContext.storeStream(is, props)
    } //if rawObj != null
} //for</script></dataprocessscript></step></dataprocess></configuration><dragpoints><dragpoint name="shape27.dragpoint1" toShape="shape16" x="1008.0" y="57.0"><linesegment length="0" name="shape27.dragpoint1.lineseg1" orient="horizontal" x="738.0" y="63.0"/><linesegment length="0" name="shape27.dragpoint1.lineseg2" orient="vertical" x="738.0" y="63.0"/><linesegment length="143" name="shape27.dragpoint1.lineseg3" orient="horizontal" x="738.0" y="63.0"/><linesegment length="0" name="shape27.dragpoint1.lineseg4" orient="vertical" x="881.0" y="63.0"/><linesegment length="127" name="shape27.dragpoint1.lineseg5" orient="horizontal" x="881.0" y="63.0"/></dragpoint></dragpoints></shape></shapes></process></bns:object><bns:processOverrides/></bns:Component>
