  "template_status": "example_only_not_reusable_template",
  "purpose": "Show the SHAPE of a build_from_archetype call that REUSES existing secured connection components (binding.mode='reuse') instead of authoring new ones — the preferred doctrine: reuse keeps credentials out of the conversation.",
  "do_not_reuse": "Every value below is a <<placeholder>> sentinel. Discover real component ids with query_components(action='list') and author all other values from the user's actual requirements.",
  "tool_call": {
