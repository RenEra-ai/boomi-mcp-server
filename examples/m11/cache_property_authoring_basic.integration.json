{
  "example_not_template": true,
  "is_template": false,
  "template_status": "example_only_not_reusable_template",
  "purpose": "M11 (#125): composed DDP/DPP authoring — a flow_sequence that sets a per-document DDP from profile+static sources, sets a persisted run-flag DPP from the current document, and routes on the DDP with a Decision. Demonstrates 1:1 same-branch carry-forward and the trunk-write-then-read lineage contract.",
  "do_not_reuse": "Concrete values below are demo-grade (example.invalid endpoints, fixed UUIDs) so the spec plans clean in tests; author real bindings from actual requirements.",
  "integration_spec": {
    "naming": {"integration_name": "M11 Basic Cache Property Demo"},
    "components": [
      {
        "key": "demo_process",
        "type": "process",
        "action": "create",
        "name": "M11 DDP DPP Basic Flow",
        "config": {
          "process_kind": "database_to_api_sync",
          "source": {
            "connector_type": "database",
            "connection_id": "11111111-1111-1111-1111-111111111111",
            "operation_id": "22222222-2222-2222-2222-222222222222",
            "action_type": "Get"
          },
          "transform": {"mode": "passthrough"},
          "target": {
            "connector_type": "rest",
            "connection_id": "33333333-3333-3333-3333-333333333333",
            "operation_id": "44444444-4444-4444-4444-444444444444",
            "action_type": "POST"
          },
          "flow_sequence": [
            {
              "kind": "set_ddp",
              "name": "DDP_ORDER_KEY",
              "label": "Build order key",
              "source_values": [
                {"value_type": "static", "value": "ORD-"},
                {
                  "value_type": "profile",
                  "element_id": "3",
                  "element_name": "orderId (Root/Object/orderId)",
                  "profile_id": "55555555-5555-5555-5555-555555555555",
                  "profile_type": "profile.json"
                }
              ]
            },
            {
              "kind": "set_dpp",
              "name": "DPP_LAST_ORDER_SEEN",
              "label": "Persist last order payload",
              "persist": true,
              "source_values": [{"value_type": "current"}]
            },
            {
              "kind": "decision",
              "comparison": "equals",
              "label": "Route unkeyed orders away",
              "left": {"value_type": "track", "property_id": "dynamicdocument.DDP_ORDER_KEY"},
              "right": {"value_type": "static", "static_value": "ORD-"},
              "true_steps": [
                {"kind": "message", "message_text": "order key missing"}
              ],
              "false_steps": [
                {"kind": "message", "message_text": "order keyed"}
              ]
            }
          ]
        }
      }
    ]
  }
}
