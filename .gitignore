*_ANALYSIS.md
OAUTH_DISCONNECT_ANALYSIS.md

# Documentation stays local, not in the remote repo — except docs/architecture/,
# which holds tracked ADRs (#135 requires the ADR and compatibility inventory
# to be tracked). A gitignored parent directory can't be re-included, so ignore
# docs/* children individually and carve out the architecture subdirectory.
docs/*
!docs/architecture/

# Test files (local only, except anywhere under tests/)
test_*.py
!tests/**/test_*.py
# Root-level scratch analysis scripts only. MUST stay anchored (leading /): an
# unanchored analyze_*.py matched the tracked package module
# src/boomi_mcp/categories/components/analyze_component.py at any depth, which
# gcloud (via .gitignore-derived upload exclusions) then dropped from local
# `gcloud builds submit` contexts, silently disabling 4 tool categories.
/analyze_*.py

# Plans (local only)
docs/plans/

# Agents (local only)
agents/

# Tasks (local only)
tasks/

# Lock files (local only)
.~lock.*

# Vendored FastMCP (replaced by upstream v3.1.1 via pip)
fastmcp/

# Incident investigation bundles
incident-*/

# Boomi companion local workspace (autogenerated, stays local)
/boomi_companion/

# Zero-license no-op QA fixture provisioner + its account-specific state (local)
scripts/provision_qa_noop_fixture.py
scripts/.qa_noop_fixture_pins.json*
